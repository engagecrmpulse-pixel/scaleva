# Copy this file to .env.local and fill in the values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs (test mode — swap for live IDs in production)
STRIPE_STARTER_PRICE_ID=price_1TfjbXArPux8IvCNwzItUFJL
STRIPE_GROWTH_PRICE_ID=price_1TfjbaArPux8IvCN59wfD0bp
STRIPE_PRO_PRICE_ID=price_1TfjbdArPux8IvCNVwRdluXC
STRIPE_ENTERPRISE_MESSAGE_PRICE_ID=price_1TfjeaArPux8IvCNOar6nWXD
STRIPE_ENTERPRISE_CUSTOMER_PRICE_ID=price_1TfjebArPux8IvCNXSM1foCw
STRIPE_CONNECT_CLIENT_ID=

# Email notifications (Resend)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# Cron security
CRON_SECRET=

# OAuth — integration connectors
SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Clover POS integration
# App ID and Secret from https://www.clover.com/developers
# Set CLOVER_ENV=sandbox for testing (default: production)
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ENV=

# App URL (used for OAuth redirects and Stripe)
NEXT_PUBLIC_APP_URL=https://scaleva.vercel.app

# Admin
ADMIN_EMAILS=

# Owner payment bypass — enter on /pricing "Have an access code?" to skip Stripe
OWNER_PAY_CODE=

# Dev bypass (development only — never set in production)
# Visit /dev-login and enter DEV_BYPASS_CODE to skip signup during iteration.
DEV_BYPASS_CODE=
DEV_EMAIL=
DEV_PASSWORD=

# Test mode — skip all Twilio calls (no SMS charges). Set true for local dev.
TEST_MODE=false
# Expose test mode to the browser (shows a banner in dashboard).
NEXT_PUBLIC_TEST_MODE=false
